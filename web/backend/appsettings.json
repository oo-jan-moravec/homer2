{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Rover": {
    "SerialPort": "/dev/serial0",
    "SerialTrace": true,
    "TelemetryReadTimeoutMs": 600,
    "DriveLockWaitMs": 5000,
    "Lcd": {
      "BusId": 1,
      "Address": 39
    }
  }
}
